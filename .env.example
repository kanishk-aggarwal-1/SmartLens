GOOGLE_MAPS_API_KEY=your_google_maps_key
AI_MODE=gemini
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash
HTTP_TIMEOUT_S=10
PROVIDER_RETRY_COUNT=2
ROUTE_CACHE_TTL_S=300
WEATHER_CACHE_TTL_S=120
STREET_VIEW_CACHE_TTL_S=300

# Redis (optional but strongly recommended for production)
# When set, ALL three TTL caches AND the metrics counters persist across
# process restarts and cold starts.  Without it everything is in-memory only.
#
# Local Redis:        REDIS_URL=redis://localhost:6379/0
# Redis Cloud / TLS:  REDIS_URL=rediss://:<password>@host:port/0
# Docker Compose:     REDIS_URL=redis://redis:6379/0  (set automatically by compose)
REDIS_URL=

# "auto"   → use Redis when REDIS_URL is set, otherwise fall back to memory
# "redis"  → require Redis (startup warning if unavailable)
# "memory" → always use in-memory (ignores REDIS_URL)
CACHE_BACKEND=auto

REQUIRE_AUTH=false
API_KEY_HASHES=
SESSION_SECRET_KEY=replace-with-random-32-byte-secret
SECRET_ENCRYPTION_KEY=generate-with-python-scripts-security_hash-py-encryption-key
SESSION_TTL_S=86400
LOGIN_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_PER_MINUTE=120
MAX_REQUEST_BODY_BYTES=1048576
ALLOWED_HOSTS=*
CORS_ORIGINS=
SECURE_COOKIES=true
HSTS_MAX_AGE_S=31536000
DATABASE_URL=sqlite:///./smartlens.db
ALLOW_SIGNUPS=true
